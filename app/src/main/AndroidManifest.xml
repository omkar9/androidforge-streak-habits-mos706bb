<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Required Permissions from ANALYZER AGENT -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" /> <!-- Recommended for AdMob -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- Permissions for exact alarms - needed for reliable reminders, especially for older Android versions -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <!-- For WorkManager to run immediately if needed, though WorkManager handles most cases -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application
        android:name=".StreakHabitsApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.StreakHabits"
        tools:targetApi="34">

        <!-- AdMob App ID -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="${ADMOB_APP_ID}" /> <!-- This will be replaced by BuildConfig.ADMOB_APP_ID -->

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.StreakHabits"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- WorkManager configurations -->
        <!-- If using HiltWorkerFactory, need to remove default WorkManager Initializer -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <!-- Custom WorkManager Initializer for Hilt. This will delegate to the application's Configuration.Provider -->
        <provider
            android:name="com.androidforge.streakhappits.core.notifications.HiltWorkerInitializer"
            android:authorities="${applicationId}.hilt-work-initializer"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.startup"
                android:value="androidx.startup" />
        </provider>

        <!-- Notification channel metadata for Android O+ -->
        <meta-data
            android:name="com.androidforge.streakhappits.NOTIFICATION_CHANNEL_ID"
            android:value="habit_reminders" />
        <meta-data
            android:name="com.androidforge.streakhappits.NOTIFICATION_CHANNEL_NAME"
            android:value="@string/notification_channel_name" />
        <meta-data
            android:name="com.androidforge.streakhappits.NOTIFICATION_CHANNEL_DESCRIPTION"
            android:value="@string/notification_channel_description" />

    </application>
</manifest>